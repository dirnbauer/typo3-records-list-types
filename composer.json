{
    "name": "webconsulting/records-list-types",
    "type": "typo3-cms-extension",
    "description": "Records List Types: multiple view modes (Grid, Compact, Teaser, custom) for the TYPO3 v14 backend Records module, with thumbnail support, per-table TSconfig, workspace-aware overlays, and PSR-14 extensibility.",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Webconsulting",
            "email": "office@webconsulting.at",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/dirnbauer/typo3-records-list-types",
    "support": {
        "issues": "https://github.com/dirnbauer/typo3-records-list-types/issues",
        "source": "https://github.com/dirnbauer/typo3-records-list-types"
    },
    "require": {
        "php": "^8.3",
        "typo3/cms-backend": "^14.0",
        "typo3/cms-core": "^14.0",
        "typo3/cms-fluid": "^14.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpat/phpat": "^0.12.2",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0",
        "saschaegerer/phpstan-typo3": "^3.0",
        "ssch/typo3-rector": "^3.0",
        "typo3/testing-framework": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Webconsulting\\RecordsListTypes\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webconsulting\\RecordsListTypes\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "records_list_types",
            "web-dir": "public"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    }
}
