# =============================================================================
# Records Grid View - Default Page TSconfig
# =============================================================================
#
# This file provides the default configuration for the Grid View extension.
# You can override these settings in your site's Page TSconfig.
#
# Documentation: EXT:records_list_types/Documentation/Configuration.md
# =============================================================================

mod.web_list {
    # Which views are available? Comma-separated: list, grid
    # Setting only "list" hides the Grid View toggle entirely
    allowedViews = list,grid

    viewMode {
        # =================================================================
        # Pagination
        # =================================================================
        # Default items per page for all view types (0 = no pagination).
        # Can be overridden per view type in types.<type>.itemsPerPage
        # itemsPerPage = 100

        types {
            # Grid view: 100 records per page (default)
            grid {
                itemsPerPage = 100
            }
            # Compact view: 300 records per page (denser layout = more records)
            compact {
                itemsPerPage = 300
            }
            # Teaser view: 100 records per page (default)
            teaser {
                itemsPerPage = 100
            }
        }
    }

    filters {
        enabled = 1
        autoDefaults = title,dateRange,hidden,categories,llm

        presets {
            title {
                type = text
                fields = label,title,header,name,username,email,teaser,description,bodytext,abstract,subheader,subtitle,nav_title,file_name,alternative
            }
            hidden {
                type = boolean
                field = hidden
            }
            dateRange {
                type = dateRange
                field = date
            }
            categories {
                type = category
                field = categories
            }
            llm {
                type = llm
                configurationIdentifier = record-list-search
                fields = label,title,header,name,username,email,teaser,description,bodytext,abstract,subheader,subtitle,nav_title,alternative
                candidateLimit = 80
                resultLimit = 25
            }
        }

        table {
            pages {
                fields = title,dateRange,hidden,categories,llm

                title {
                    fields = title,nav_title,subtitle,abstract,description
                }
                llm {
                    fields = title,nav_title,subtitle,abstract,description
                }
            }
            tt_content {
                fields = title,dateRange,hidden,categories,llm

                title {
                    fields = header,subheader,bodytext
                }
                llm {
                    fields = header,subheader,bodytext
                }
            }
            sys_category {
                fields = title,dateRange
            }
            sys_file_metadata {
                fields = title,dateRange,llm

                title {
                    fields = title,alternative,description
                }
                llm {
                    fields = title,alternative,description
                }
            }
            fe_users {
                fields = title,dateRange,hidden,categories,llm

                title {
                    fields = name,username,email,company
                }
                llm {
                    fields = name,username,email,company
                }
            }
            tx_news_domain_model_news {
                fields = title,dateRange,categories,topNews,hidden,llm

                title {
                    fields = title,teaser
                }
                dateRange {
                    field = datetime
                }
                topNews {
                    type = boolean
                    field = istopnews
                    label = Top News
                    falseLabel = LLL:EXT:records_list_types/Resources/Private/Language/locallang.xlf:filter.option.no
                    trueLabel = LLL:EXT:records_list_types/Resources/Private/Language/locallang.xlf:filter.option.yes
                }
                llm {
                    fields = title,teaser,bodytext
                }
            }
            tx_news_domain_model_category {
                fields = title,dateRange,hidden
            }
            tx_news_domain_model_tag {
                fields = title,dateRange
            }
            tx_news_domain_model_author {
                fields = title,dateRange,hidden
            }

            # LLM filters are active for the text-heavy tables above. If
            # EXT:nr_llm is missing, the record-list-search configuration does
            # not exist or no provider is available, the filter panel shows a
            # warning instead of the LLM textarea.
        }
    }

    gridView {
        # Default view when no user preference exists
        # Options: list, grid
        default = list

        # Number of columns in the grid (Bootstrap row-cols-xl-*)
        # Valid range: 2-6
        cols = 4

        # =================================================================
        # Per-Table Configuration Examples
        # =================================================================
        # Uncomment and adjust these examples for your tables.
        # You can also add these in your site's Page TSconfig.

        table {
            # -----------------------------------------------------------------
            # Pages
            # -----------------------------------------------------------------
            pages {
                titleField = title
                descriptionField = abstract
                imageField = media
                preview = 1
            }

            # -----------------------------------------------------------------
            # Content Elements
            # -----------------------------------------------------------------
            tt_content {
                titleField = header
                descriptionField = bodytext
                imageField = image
                preview = 1
            }

            # -----------------------------------------------------------------
            # Frontend Users
            # -----------------------------------------------------------------
            fe_users {
                titleField = name
                descriptionField = email
                imageField = image
                preview = 1
            }

            # -----------------------------------------------------------------
            # News (EXT:news)
            # -----------------------------------------------------------------
            tx_news_domain_model_news {
                titleField = title
                descriptionField = teaser
                imageField = fal_media
                preview = 1
            }
        }
    }
}
